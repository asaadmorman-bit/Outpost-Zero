{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "array",
  "items": {
    "type": "object",
    "properties": {
      "timestamp": { "type": "string" },
      "host_identity": { "type": "string" },
      "process_path": { "type": "string" },
      "integrity_status": { "type": "string", "enum": ["TRUSTED", "UNTRUSTED", "UNKNOWN"] },
      "pid": { "type": "integer" },
      "process_hash": { "type": "string" },
      "parent_pid": { "type": "integer" }
    },
    "required": ["timestamp", "host_identity", "process_path", "integrity_status", "pid", "process_hash"]
  }
}